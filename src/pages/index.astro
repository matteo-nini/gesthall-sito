.demo-inner > p { font-size: 16px; color: var(--muted) }
.demo-form { display: flex; gap: 10px; width: 100% }
.demo-form input { flex: 1; padding: 13px 18px; border-radius: var(--rx-m); background: var(--bg); border: 1px solid var(--border); color: var(--text); font-family: var(--font-body); font-size: 15px; outline: none; transition: border-color 0.15s }
.demo-form input:focus { border-color: oklch(0.72 0.16 168 / 0.6) }
.demo-form input::placeholder { color: var(--faint) }
.demo-note { font-size: 13px; color: var(--faint) }
