---
import Layout from '../layouts/Layout.astro';
import { features, byPlan } from '../data/features.ts';
---

<Layout>

<!-- ── HERO ────────────────────────────────────────────────── -->
<section class="hero">
  <div class="container hero-inner">

    <div class="hero-text">
      <div class="hero-pill">Gestionale · VLT · AWP · Made in Italy</div>
      <h1>Chiudi la cassa<br>in 5 minuti.<br>Ogni sera.</h1>
      <p class="hero-sub">Il primo gestionale costruito per le sale giochi italiane. Scassettamenti, turni, firma versamenti digitale, notifiche push. Niente fogli Excel alle 23:00.</p>
      <div class="hero-actions">
        <a href="#demo" class="btn btn-primary">
          Prova la demo
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
        </a>
        <a href="#prezzi" class="btn btn-ghost">Vedi i piani</a>
      </div>
    </div>

    <div class="hero-visual" aria-hidden="true">
      <div class="mock">
        <div class="mock-chrome">
          <div class="mock-dots"><span></span><span></span><span></span></div>
          <div class="mock-url">app.gesthallsuite.it</div>
          <div style="width:48px"></div>
        </div>
        <div class="mock-app">
          <div class="mock-sb">
            <div class="mock-sb-logo">
              <svg width="20" height="20" viewBox="0 0 20 20"><rect width="20" height="20" rx="5" fill="oklch(0.72 0.16 168)"/><rect x="3" y="3" width="5" height="6" rx="1" fill="oklch(0.1 0 0 / 0.3)"/><rect x="12" y="3" width="5" height="6" rx="1" fill="oklch(0.1 0 0 / 0.3)"/><rect x="3" y="11" width="5" height="6" rx="1" fill="oklch(0.1 0 0 / 0.3)"/><rect x="12" y="11" width="5" height="6" rx="1" fill="oklch(0.1 0 0 / 0.7)"/></svg>
            </div>
            <div class="mock-sb-items">
              <div class="mock-sb-item"><svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="1" width="5" height="5" rx="1"/><rect x="8" y="1" width="5" height="5" rx="1"/><rect x="1" y="8" width="5" height="5" rx="1"/><rect x="8" y="8" width="5" height="5" rx="1"/></svg></div>
              <div class="mock-sb-item active"><svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="2" width="12" height="10" rx="1.5"/><path d="M9 1v3M5 1v3M1 6h12"/></svg></div>
              <div class="mock-sb-item"><svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="2" width="12" height="10" rx="1.5"/><path d="M9 1v3M5 1v3M1 6h12M4 9h1M6.5 9h1M9 9h1"/></svg></div>
              <div class="mock-sb-item"><svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 5a4 4 0 0 1 0 4v1a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V5a4 4 0 0 1 0-4V3a1 1 0 0 0-1-1H2a1 1 0 0 0-1 1z"/></svg></div>
            </div>
            <div class="mock-sb-foot">
              <div class="mock-sb-avatar">MN</div>
            </div>
          </div>
          <div class="mock-main">
            <div class="mock-hdr">
              <span class="mock-hdr-date">Lun 7 luglio 2026</span>
              <span class="mock-hdr-badge">Aperta</span>
            </div>
            <div class="mock-kpis">
              <div class="mock-kpi"><div class="mock-kpi-label">Versamento</div><div class="mock-kpi-val">€&nbsp;7.820</div></div>
              <div class="mock-kpi"><div class="mock-kpi-label">Scassettamenti</div><div class="mock-kpi-val">€&nbsp;12.460</div></div>
            </div>
            <div class="mock-tabs">
              <span class="mock-tab">Turno 1</span>
              <span class="mock-tab on"><span class="mock-tab-dot"></span>Turno 2</span>
            </div>
            <div class="mock-rows">
              <div class="mock-row"><span class="mock-rl">Fondo cassa</span><span class="mock-rv">€ 300</span></div>
              <div class="mock-row"><span class="mock-rl">Scassettamenti</span><span class="mock-rv">€ 8.460</span></div>
              <div class="mock-row"><span class="mock-rl">Bancomat</span><span class="mock-rv">€ 420</span></div>
              <div class="mock-row"><span class="mock-rl">Ticket pagati</span><span class="mock-rv">€ 220</span></div>
            </div>
            <div class="mock-result">
              <span class="mock-rl-acc">Versamento netto</span>
              <span class="mock-rv-acc">€ 7.820</span>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- ── TRUST STRIP ──────────────────────────────────────────── -->
<div class="trust-strip">
  <div class="container">
    <ul class="trust-items" role="list">
      <li>VLT &amp; AWP</li>
      <li>SNAI · Betwin</li>
      <li>Firma digitale ADM</li>
      <li>PWA iOS &amp; Android</li>
      <li>Notifiche push</li>
      <li>Supporto in italiano</li>
    </ul>
  </div>
</div>

<!-- ── 3 FEATURE HIGHLIGHTS ─────────────────────────────────── -->
<section class="section feat-section" id="funzionalita">
  <div class="container">
    <div class="sect-header reveal">
      <h2>Costruito per chi chiude<br>i conti ogni sera.</h2>
      <p>Non un gestionale generico adattato alle sale: un prodotto pensato da zero per VLT e AWP italiani.</p>
    </div>

    <!-- 1. Cassa giornaliera -->
    <div class="feat-row reveal">
      <div class="feat-row-text">
        <div class="feat-tag">Cassa giornaliera</div>
        <h2>Cassetto e versamento<br>calcolati in tempo reale.</h2>
        <p>Inserisci contanti, bancomat, ticket e scassettamenti. Il calcolo avviene mentre scrivi: nessun foglio Excel, nessun errore di somma alle 23:00.</p>
        <ul class="feat-checklist">
          <li>Doppio turno mattino e sera separati</li>
          <li>Banner verde/rosso immediato sulla quadratura</li>
          <li>Email automatica ai revisori alla chiusura</li>
          <li>Storico giornaliero completo e immutabile</li>
        </ul>
        <a href="/funzionalita/cassa-giornaliera" class="feat-link">
          Scopri la cassa giornaliera
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M2 7h10M8 3l4 4-4 4"/></svg>
        </a>
      </div>
      <div class="feat-row-visual" aria-hidden="true">
        <div class="feat-mock-card">
          <div class="fmc-header">
            <span class="fmc-title">Cassa · Turno 2</span>
            <span class="fmc-badge">Aperta</span>
          </div>
          <div class="fmc-body">
            <div class="fmc-kpis">
              <div class="fmc-kpi"><div class="fmc-kpi-l">Versamento</div><div class="fmc-kpi-v">€ 7.820</div></div>
              <div class="fmc-kpi"><div class="fmc-kpi-l">Scassettamenti</div><div class="fmc-kpi-v">€ 12.460</div></div>
            </div>
            <div class="fmc-rows">
              <div class="fmc-row"><span>Fondo cassa</span><span>€ 300,00</span></div>
              <div class="fmc-row"><span>Scassettamenti totali</span><span>€ 12.460,00</span></div>
              <div class="fmc-row"><span>Bancomat</span><span>€ 420,00</span></div>
              <div class="fmc-row"><span>Ticket pagati</span><span>€ 220,00</span></div>
            </div>
            <div class="fmc-result">
              <span>Versamento netto</span>
              <strong>€ 11.820,00</strong>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- 2. Firma digitale -->
    <div class="feat-row feat-row-rev reveal">
      <div class="feat-row-text">
        <div class="feat-tag">Firma digitale</div>
        <h2>Ogni versamento firmato,<br>tracciato, inattaccabile.</h2>
        <p>Il revisore firma il ritiro su canvas touch da qualsiasi dispositivo. Firma PNG, timestamp e IP vengono salvati immutabilmente insieme all'importo dichiarato.</p>
        <ul class="feat-checklist">
          <li>Firma manuale su tablet, smartphone o PC</li>
          <li>Dati salvati immutabilmente lato server</li>
          <li>Badge "Confermato" visibile a tutti</li>
          <li>Storico completo per il responsabile</li>
        </ul>
        <a href="/funzionalita/firma-digitale" class="feat-link">
          Scopri la firma digitale
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M2 7h10M8 3l4 4-4 4"/></svg>
        </a>
      </div>
      <div class="feat-row-visual" aria-hidden="true">
        <div class="feat-mock-card">
          <div class="fmc-header">
            <span class="fmc-title">Conferma versamento</span>
          </div>
          <div class="fmc-body">
            <div class="fmc-firma-info">
              <span>Giornata</span><strong>7 luglio 2026</strong>
              <span>Importo</span><strong class="fmc-firma-amount">€ 7.820,00</strong>
            </div>
            <div class="fmc-firma-canvas">
              <svg viewBox="0 0 220 64" width="100%" height="64" aria-hidden="true">
                <path d="M15 50 C30 15, 55 60, 75 40 C90 25, 105 55, 125 35 C140 20, 158 50, 185 38 C200 28, 210 45, 218 40" stroke="oklch(0.72 0.16 168)" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <div class="fmc-firma-label">Firma del revisore · 22:14 · IP 10.0.0.5</div>
            </div>
            <div class="fmc-firma-btn">Conferma ritiro</div>
          </div>
        </div>
      </div>
    </div>

    <!-- 3. App mobile -->
    <div class="feat-row reveal">
      <div class="feat-row-text">
        <div class="feat-tag">App mobile & push</div>
        <h2>Installa una volta.<br>Notifiche per sempre.</h2>
        <p>PWA installabile su iPhone e Android senza app store. Notifiche push native per versamenti confermati e ticket di guasto. Il gestionale in tasca, sempre aggiornato.</p>
        <ul class="feat-checklist">
          <li>Installazione dal browser in 3 secondi</li>
          <li>Notifiche push native iOS e Android</li>
          <li>Preferenze per tipo di notifica per utente</li>
          <li>Swipe tra turni su mobile</li>
        </ul>
        <a href="/funzionalita/app-mobile" class="feat-link">
          Scopri l'app mobile
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M2 7h10M8 3l4 4-4 4"/></svg>
        </a>
      </div>
      <div class="feat-row-visual" aria-hidden="true">
        <div class="feat-phone-wrap">
          <div class="feat-phone">
            <div class="feat-phone-notch"></div>
            <div class="feat-phone-bar">GestHall Suite</div>
            <div class="feat-phone-content">
              <div class="fpc-notif">
                <div class="fpc-notif-icon">
                  <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16"><path d="M8 1a4 4 0 0 0-4 4c0 4.5-2 5.5-2 5.5h12s-2-1-2-5.5a4 4 0 0 0-4-4z"/><path d="M9.7 14a1.9 1.9 0 0 1-3.4 0"/></svg>
                </div>
                <div>
                  <div class="fpc-notif-title">GestHall Suite</div>
                  <div class="fpc-notif-body">Versamento confermato · € 7.820</div>
                </div>
              </div>
              <div class="fpc-kpi-row">
                <div class="fpc-kpi"><div class="fpc-kpi-l">Oggi</div><div class="fpc-kpi-v">€ 7.820</div></div>
                <div class="fpc-kpi"><div class="fpc-kpi-l">Settimana</div><div class="fpc-kpi-v">€ 41.200</div></div>
              </div>
              <div class="fpc-btn">Apri cassa →</div>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- ── ALL FEATURES GRID ─────────────────────────────────────── -->
<section class="section all-feat-section">
  <div class="container">
    <div class="sect-header reveal">
      <h2>Dieci funzionalità.<br>Un solo gestionale.</h2>
      <p>Dal piano base alle funzionalità Suite: ogni strumento è pensato per le sale giochi italiane.</p>
    </div>

    {(['essenziale', 'pro', 'suite'] as const).map(plan => (
      <div class="af-plan-group reveal">
        <div class={`af-plan-label af-label-${plan}`}>
          {plan === 'essenziale' && 'Essenziale — da €39/mese'}
          {plan === 'pro'        && 'Pro — da €69/mese'}
          {plan === 'suite'      && 'Suite — da €99/mese'}
        </div>
        <div class="af-grid">
          {byPlan[plan].map(f => (
            <a href={f.slug} class="af-card">
              <div class="af-card-icon" set:html={f.icon}></div>
              <div class="af-card-body">
                <div class="af-card-name">{f.name}</div>
                <div class="af-card-desc">{f.desc}</div>
              </div>
              <svg class="af-card-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M2 7h10M8 3l4 4-4 4"/></svg>
            </a>
          ))}
        </div>
      </div>
    ))}

    <div class="af-footer reveal">
      <a href="/funzionalita" class="btn btn-ghost">Esplora tutte le funzionalità →</a>
    </div>
  </div>
</section>

<!-- ── PRICING ──────────────────────────────────────────────── -->
<section class="section pricing-section" id="prezzi">
  <div class="container">
    <div class="sect-header reveal">
      <h2>Prezzi chiari.<br>Nessuna sorpresa.</h2>
      <p>Abbonamento mensile o annuale. Annulla quando vuoi. Migrazione dati inclusa.</p>
    </div>
    <div class="pricing-grid">

      <div class="plan reveal">
        <div class="plan-name">Essenziale</div>
        <div class="plan-price"><span class="plan-eur">€</span>39<span class="plan-mo">/mese</span></div>
        <div class="plan-annual">o €390/anno · risparmi 2 mesi</div>
        <a href="/contatti" class="btn btn-ghost plan-btn">Inizia gratis</a>
        <ul class="plan-features">
          <li>Cassa giornaliera e turni</li>
          <li>VLT e AWP illimitati</li>
          <li>Fino a 4 operatori</li>
          <li>Report settimanale e mensile</li>
          <li>PWA mobile (iOS e Android)</li>
          <li>Export dati XLS</li>
          <li>Supporto via email</li>
        </ul>
      </div>

      <div class="plan plan-featured reveal d1">
        <div class="plan-badge">Più scelto</div>
        <div class="plan-name">Pro</div>
        <div class="plan-price"><span class="plan-eur">€</span>69<span class="plan-mo">/mese</span></div>
        <div class="plan-annual">o €690/anno · risparmi 2 mesi</div>
        <a href="/contatti" class="btn btn-primary plan-btn">Inizia gratis</a>
        <ul class="plan-features">
          <li>Tutto di Essenziale</li>
          <li>Operatori illimitati</li>
          <li>Anagrafica giocatori</li>
          <li>Prestiti e rientri</li>
          <li>Documenti e archivi</li>
          <li>Ticket assistenza macchine</li>
          <li>Notifiche push iOS e Android</li>
          <li>Firma digitale versamenti</li>
          <li>Confronto periodi avanzato</li>
        </ul>
      </div>

      <div class="plan reveal d2">
        <div class="plan-name">Suite</div>
        <div class="plan-price"><span class="plan-eur">€</span>99<span class="plan-mo">/mese</span></div>
        <div class="plan-annual">o €990/anno · risparmi 2 mesi</div>
        <a href="/contatti" class="btn btn-ghost plan-btn">Inizia gratis</a>
        <ul class="plan-features">
          <li>Tutto di Pro</li>
          <li>Chat interna tra operatori</li>
          <li>Web Radio streaming</li>
          <li>White-label (logo e colori)</li>
          <li>Passaggio consegne con checklist</li>
          <li>Integrazione SONOS</li>
          <li>Supporto prioritario</li>
          <li>Istanza demo per rivenditori</li>
          <li>Onboarding dedicato</li>
        </ul>
      </div>

    </div>
    <p class="pricing-note reveal">Tutti i piani includono installazione su hosting proprio, aggiornamenti, e 14 giorni di prova gratuita senza carta di credito.</p>
  </div>
</section>

<!-- ── RESELLERS ────────────────────────────────────────────── -->
<section class="section resellers-section" id="rivenditori">
  <div class="container">
    <div class="resellers-inner reveal">
      <div class="resellers-text">
        <div class="resellers-tag">Per rivenditori</div>
        <h2>Installi software per le sale?<br>GestHall Suite è fatto per te.</h2>
        <p>White-label completo, setup in meno di un'ora su qualsiasi hosting PHP, pannello di gestione multi-installazione. Il tuo brand sul prodotto, il tuo margine su ogni abbonamento.</p>
        <ul class="feat-checklist">
          <li>Logo e colori del tuo cliente su ogni installazione</li>
          <li>Demo instance preconfigurata per presentazioni</li>
          <li>Documentazione tecnica e guide di installazione</li>
          <li>Supporto prioritario per i rivenditori certificati</li>
        </ul>
        <a href="/contatti" class="btn btn-primary" style="margin-top: 32px">Parla con noi →</a>
      </div>
      <div class="resellers-visual" aria-hidden="true">
        <div class="resellers-mockup">
          <div class="rm-header">Dashboard rivenditore</div>
          <div class="rm-installs">
            <div class="rm-install">
              <div class="rm-dot rm-dot-green"></div>
              <div><div class="rm-name">Sala Fortuna — Napoli</div><div class="rm-sub">Piano Pro · Attivo</div></div>
              <div class="rm-plan">Pro</div>
            </div>
            <div class="rm-install">
              <div class="rm-dot rm-dot-green"></div>
              <div><div class="rm-name">New Game — Torino</div><div class="rm-sub">Piano Suite · Attivo</div></div>
              <div class="rm-plan rm-plan-suite">Suite</div>
            </div>
            <div class="rm-install">
              <div class="rm-dot rm-dot-amber"></div>
              <div><div class="rm-name">Lucky Star — Roma</div><div class="rm-sub">Piano Essenziale · Trial</div></div>
              <div class="rm-plan rm-plan-ess">Ess.</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── DEMO CTA ─────────────────────────────────────────────── -->
<section class="section demo-section" id="demo">
  <div class="container">
    <div class="demo-inner reveal">
      <h2>Prova GestHall Suite<br>senza impegno.</h2>
      <p>14 giorni gratuiti, nessuna carta di credito. Installazione su hosting inclusa nel primo mese.</p>
      <form class="demo-form" id="demo-form" novalidate>
        <input type="email" name="email" placeholder="La tua email" required autocomplete="email" />
        <button type="submit" class="btn btn-primary">Inizia la prova →</button>
      </form>
      <p class="demo-note" id="demo-note">Oppure scrivici a <a href="mailto:info@gesthallsuite.it">info@gesthallsuite.it</a></p>
    </div>
  </div>
</section>

</Layout>

<style>
/* ── HERO ─────────────────────────────────────────────────── */
.hero { padding: 120px 0 80px; min-height: 100dvh; display: flex; align-items: center; background: linear-gradient(155deg, oklch(100% 0 0) 0%, oklch(96% 0.012 245) 100%) }
.hero-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center }
.hero-text { display: flex; flex-direction: column; gap: 24px }
.hero-pill {
  display: inline-flex; align-items: center; padding: 6px 14px; border-radius: 999px;
  background: var(--accent-sub); border: 1px solid oklch(0.72 0.16 168 / 0.25);
  color: var(--accent); font-size: 13px; font-weight: 600; width: fit-content;
  animation: fadeUp 0.7s var(--ease) 0s both;
}
.hero-text h1 { font-size: clamp(2.6rem, 4.5vw, 4.4rem); font-weight: 800; color: var(--text); animation: fadeUp 0.8s var(--ease) 0.08s both }
.hero-sub { font-size: 17px; color: var(--muted); max-width: 48ch; line-height: 1.7; animation: fadeUp 0.8s var(--ease) 0.17s both }
.hero-actions { display: flex; flex-wrap: wrap; gap: 12px; animation: fadeUp 0.8s var(--ease) 0.26s both }
.hero-visual { animation: fadeIn 1s var(--ease) 0.12s both }

@keyframes fadeUp { from { opacity: 0; transform: translateY(22px) } to { opacity: 1; transform: none } }
@keyframes fadeIn { from { opacity: 0; transform: translateY(14px) } to { opacity: 1; transform: none } }

/* ── HERO MOCK ────────────────────────────────────────────── */
.mock { background: var(--bg); border-radius: 12px; overflow: hidden; border: 1px solid var(--border); box-shadow: 0 28px 72px oklch(19% 0.075 245 / 0.12), 0 4px 16px oklch(19% 0.075 245 / 0.06) }
.mock-chrome { background: var(--surface-2); padding: 10px 14px; display: flex; align-items: center; gap: 8px; border-bottom: 1px solid var(--border) }
.mock-dots { display: flex; gap: 5px }
.mock-dots span { width: 9px; height: 9px; border-radius: 50%; background: var(--border) }
.mock-url { flex: 1; text-align: center; font-size: 11px; color: var(--faint); font-family: var(--font-body) }
.mock-app { display: flex; height: 290px }
.mock-sb { width: 52px; background: var(--surface); border-right: 1px solid var(--border); display: flex; flex-direction: column; align-items: center; padding: 12px 0 10px; gap: 4px }
.mock-sb-logo { width: 28px; height: 28px; margin-bottom: 12px; display: flex; align-items: center; justify-content: center }
.mock-sb-items { display: flex; flex-direction: column; gap: 2px }
.mock-sb-item { width: 34px; height: 28px; border-radius: 6px; display: flex; align-items: center; justify-content: center; color: var(--faint) }
.mock-sb-item svg { width: 14px; height: 14px }
.mock-sb-item.active { background: var(--accent-sub); color: var(--accent) }
.mock-sb-foot { margin-top: auto }
.mock-sb-avatar { width: 28px; height: 28px; border-radius: 50%; background: var(--surface-2); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 8px; font-weight: 700; color: var(--muted) }
.mock-main { flex: 1; padding: 12px 14px 10px; display: flex; flex-direction: column; gap: 10px; background: var(--bg) }
.mock-hdr { display: flex; align-items: center; gap: 8px }
