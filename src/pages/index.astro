.plan-badge { position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: var(--accent); color: oklch(0.1 0 0); font-size: 11px; font-weight: 700; padding: 4px 14px; border-radius: 999px; white-space: nowrap }
