---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Diventa rivenditore GestHall Suite · Pannello multi-installazione"
  description="Vendi GestHall Suite come tuo prodotto. White-label completo, pannello hub per gestire tutte le installazioni, ghost login, license API. Il tuo brand, il tuo margine."
>

<!-- ── HERO ─────────────────────────────────────────────────── -->
<section class="rv-hero">
  <div class="container rv-hero-inner">
    <div class="rv-hero-text reveal-once">
      <nav class="rv-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">›</span>
        <span>Rivenditori</span>
      </nav>
      <div class="rv-tag">Programma rivenditori</div>
      <h1>Vendi GestHall Suite.<br>Sotto il tuo nome.</h1>
      <p class="rv-sub">White-label completo, pannello hub per gestire tutte le installazioni dei tuoi clienti, ghost login sicuro e license API automatica. Tutto ciò di cui hai bisogno per rivendere un software gestionale professionale senza costruirlo da zero.</p>
      <div class="rv-actions">
        <a href="/contatti" class="btn btn-primary">Diventa rivenditore →</a>
        <a href="#come-funziona" class="btn btn-ghost">Come funziona</a>
      </div>
    </div>
    <div class="rv-hero-visual" aria-hidden="true">
      <!-- Hub dashboard mockup -->
      <div class="hub-mock">
        <div class="hub-topbar">
          <div class="hub-topbar-logo">
            <svg width="20" height="20" viewBox="0 0 34 34"><rect width="34" height="34" rx="8" fill="oklch(0.72 0.16 168)"/><rect x="6" y="6" width="9" height="10" rx="2" fill="oklch(0.1 0 0 / 0.32)"/><rect x="19" y="6" width="9" height="10" rx="2" fill="oklch(0.1 0 0 / 0.32)"/><rect x="6" y="19" width="9" height="10" rx="2" fill="oklch(0.1 0 0 / 0.32)"/><rect x="19" y="19" width="9" height="10" rx="2" fill="oklch(0.1 0 0 / 0.72)"/></svg>
            <span>GestHall Hub</span>
          </div>
          <div class="hub-topbar-user">● Rivenditore Rossi</div>
        </div>
        <div class="hub-body">
          <aside class="hub-sidebar">
            <div class="hub-sn-item hub-sn-active">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
              Installazioni
            </div>
            <div class="hub-sn-item">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              License API
            </div>
            <div class="hub-sn-item">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              Profilo
            </div>
          </aside>
          <main class="hub-main">
            <div class="hub-main-head">
              <span class="hub-main-title">Le tue installazioni</span>
              <span class="hub-kpi">3 attive</span>
            </div>
            <div class="hub-installs">
              <div class="hub-row">
                <div class="hub-dot hub-dot-green"></div>
                <div class="hub-row-info">
                  <div class="hub-row-name">Sala Fortuna</div>
                  <div class="hub-row-sub">Napoli · scade 30/09/2026</div>
                </div>
                <div class="hub-badge hub-badge-pro">Pro</div>
                <button class="hub-ghost-btn">Accedi</button>
              </div>
              <div class="hub-row">
                <div class="hub-dot hub-dot-green"></div>
                <div class="hub-row-info">
                  <div class="hub-row-name">New Game</div>
                  <div class="hub-row-sub">Torino · scade 15/10/2026</div>
                </div>
                <div class="hub-badge hub-badge-suite">Suite</div>
                <button class="hub-ghost-btn">Accedi</button>
              </div>
              <div class="hub-row">
                <div class="hub-dot hub-dot-amber"></div>
                <div class="hub-row-info">
                  <div class="hub-row-name">Lucky Star</div>
                  <div class="hub-row-sub">Roma · trial 14 gg</div>
                </div>
                <div class="hub-badge hub-badge-ess">Essenz.</div>
                <button class="hub-ghost-btn">Accedi</button>
              </div>
            </div>
          </main>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── NUMBERS ───────────────────────────────────────────────── -->
<section class="rv-numbers">
  <div class="container">
    <div class="rv-numbers-grid reveal">
      <div class="rv-num">
        <div class="rv-num-val">€39–99</div>
        <div class="rv-num-label">abbonamento mensile per installazione</div>
      </div>
      <div class="rv-num">
        <div class="rv-num-val">&lt; 1 ora</div>
        <div class="rv-num-label">tempo di setup su hosting PHP standard</div>
      </div>
      <div class="rv-num">
        <div class="rv-num-val">3 piani</div>
        <div class="rv-num-label">Essenziale, Pro, Suite — scegli tu il margine</div>
      </div>
      <div class="rv-num">
        <div class="rv-num-val">100%</div>
        <div class="rv-num-label">white-label: il gestore vede solo il tuo brand</div>
      </div>
    </div>
  </div>
</section>

<!-- ── HUB EXPLAIN ──────────────────────────────────────────── -->
<section class="section rv-hub-section" id="hub">
  <div class="container">
    <div class="rv-section-label">Il pannello centrale</div>
    <h2 class="rv-section-title">hub.gesthallsuite.it — il tuo quartier generale</h2>
    <p class="rv-section-sub">Ogni rivenditore certificato accede a un pannello dedicato per gestire tutte le installazioni dei propri clienti da un'unica interfaccia. Nessun accesso ai dati dei clienti altrui, solo le tue.</p>

    <div class="rv-hub-grid reveal">
      <div class="rv-hub-card">
        <div class="rv-hub-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        </div>
        <h3>Dashboard multi-installazione</h3>
        <p>Tutte le installazioni in un'unica tabella: nome sala, città, piano attivo, data scadenza, stato. Filtro e ricerca istantanei.</p>
      </div>
      <div class="rv-hub-card">
        <div class="rv-hub-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
        </div>
        <h3>Ghost login sicuro</h3>
        <p>Accedi all'app di un cliente con un click — senza conoscere la sua password. Il link è firmato HMAC-SHA256, valido 15 minuti, e ogni accesso viene registrato nel log.</p>
      </div>
      <div class="rv-hub-card">
        <div class="rv-hub-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
        </div>
        <h3>License API automatica</h3>
        <p>Ogni installazione si autentica verso <code>hub.gesthallsuite.it/api/license</code> e riceve piano, scadenza e funzionalità abilitate. Nessun file di licenza da gestire manualmente.</p>
      </div>
      <div class="rv-hub-card">
        <div class="rv-hub-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        </div>
        <h3>Gestione piani</h3>
        <p>Cambia piano e scadenza di un'installazione direttamente dalla scheda cliente nel hub. Attualmente manuale, in futuro integrato con Stripe Checkout e webhook automatici.</p>
      </div>
      <div class="rv-hub-card">
        <div class="rv-hub-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </div>
        <h3>Demo instance inclusa</h3>
        <p>I rivenditori certificati ricevono un'istanza demo già preconfigurata con dati di esempio. Pronta per le presentazioni ai potenziali clienti senza setup.</p>
      </div>
      <div class="rv-hub-card">
        <div class="rv-hub-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
        </div>
        <h3>Documentazione tecnica</h3>
        <p>Guide di installazione su Apache/Nginx, configurazione database MySQL, aggiornamenti e migrazione schema SQL. Tutto in un unico portale riservato.</p>
      </div>
    </div>
  </div>
</section>

<!-- ── WHITE LABEL ──────────────────────────────────────────── -->
<section class="section rv-wl-section">
  <div class="container">
    <div class="rv-wl-inner reveal">
      <div class="rv-wl-text">
        <div class="rv-section-label">White-label completo</div>
        <h2>Il gestore vede il tuo brand.<br>Non il nostro.</h2>
        <p>Ogni installazione ha logo, colori e nome della sala configurati dal rivenditore. Le email automatiche (chiusura cassa, reset password, nuovo account) escono con il brand del cliente. La PWA installata sul telefono dell'operatore ha l'icona che scegli tu.</p>
        <ul class="rv-checklist">
          <li>Logo personalizzato per ogni installazione</li>
          <li>Colore accento con derivazione automatica delle varianti</li>
          <li>Email con header e footer brandizzati</li>
          <li>PWA con nome e icona del cliente (manifest dinamico)</li>
          <li>Nessun riferimento a GestHall Suite visibile all'utente finale</li>
        </ul>
        <a href="/funzionalita/white-label" class="rv-link">Approfondisci il white-label →</a>
      </div>
      <div class="rv-wl-visual" aria-hidden="true">
        <div class="wl-phone">
          <div class="wlp-bar">
            <div class="wlp-logo-row">
              <div class="wlp-logo">SF</div>
              <div>
                <div class="wlp-name">Sala Fortuna</div>
                <div class="wlp-plan">Piano Pro · Attivo</div>
              </div>
            </div>
          </div>
          <div class="wlp-body">
            <div class="wlp-nav-item wlp-nav-active">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
              Cassa
            </div>
            <div class="wlp-nav-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/><path d="M8 14h.01M12 14h.01"/></svg>
              Turni
            </div>
            <div class="wlp-nav-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              Mail
            </div>
          </div>
          <div class="wlp-email">
            <div class="wlp-email-head">
              <div class="wlp-email-logo">SF</div>
              <div>
                <div class="wlp-email-from">Sala Fortuna</div>
                <div class="wlp-email-sub">Riepilogo versamento 14/07/2026</div>
              </div>
            </div>
            <div class="wlp-email-line"></div>
            <div class="wlp-email-line short"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── HOW IT WORKS ─────────────────────────────────────────── -->
<section class="section rv-steps-section" id="come-funziona">
  <div class="container">
    <div class="rv-section-label">Il processo</div>
    <h2 class="rv-section-title">Da zero al primo cliente attivo</h2>

    <div class="rv-steps reveal">
      <div class="rv-step">
        <div class="rv-step-num">01</div>
        <div class="rv-step-body">
          <h3>Contattaci e vieni onboardato</h3>
          <p>Compila il form di contatto selezionando "Programma rivenditori". Entro 48h fissiamo una call per presentarti il prodotto, rispondere alle domande tecniche e valutare insieme la compatibilità con il tuo portafoglio clienti.</p>
        </div>
      </div>
      <div class="rv-step">
        <div class="rv-step-num">02</div>
        <div class="rv-step-body">
          <h3>Accesso all'hub e istanza demo</h3>
          <p>Ricevi le credenziali per <code>hub.gesthallsuite.it</code> e un'istanza demo preconfigurata per le presentazioni. Hai accesso alla documentazione tecnica completa e alle guide di installazione su hosting PHP condiviso.</p>
        </div>
      </div>
      <div class="rv-step">
        <div class="rv-step-num">03</div>
        <div class="rv-step-body">
          <h3>Installi, personalizzi, consegni</h3>
          <p>Per ogni nuovo cliente: setup in meno di un'ora su qualsiasi hosting PHP con MySQL, configurazione brand (logo + colori), creazione del responsabile iniziale. Tutto da linea di comando o pannello hosting. Zero dipendenze da cloud o servizi terzi.</p>
        </div>
      </div>
      <div class="rv-step">
        <div class="rv-step-num">04</div>
        <div class="rv-step-body">
          <h3>Gestisci tutto dall'hub</h3>
          <p>L'installazione compare automaticamente nel tuo pannello hub. Da lì puoi accedere in ghost login per il supporto, vedere lo stato della licenza, cambiare piano e monitorare la scadenza di ogni cliente senza comunicare con noi.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── PIANI ─────────────────────────────────────────────────── -->
<section class="section rv-plans-section">
  <div class="container">
    <div class="rv-section-label">Prezzi al cliente</div>
    <h2 class="rv-section-title">Tre piani, tu scegli il tuo margine</h2>
    <p class="rv-section-sub">Questi sono i prezzi base di GestHall Suite. Il rivenditore stabilisce liberamente il prezzo finale per il proprio cliente.</p>

    <div class="rv-plans reveal">
      <div class="rv-plan">
        <div class="rv-plan-head rv-plan-ess">Essenziale</div>
        <div class="rv-plan-price">€39<span>/mese</span></div>
        <ul class="rv-plan-features">
          <li>Cassa giornaliera VLT/AWP</li>
          <li>Scassettamenti e report</li>
          <li>Gestione turni</li>
          <li>Dashboard responsabile</li>
          <li>Fino a 4 utenti attivi</li>
        </ul>
      </div>
      <div class="rv-plan rv-plan-featured">
        <div class="rv-plan-badge">Più venduto</div>
        <div class="rv-plan-head rv-plan-pro">Pro</div>
        <div class="rv-plan-price">€69<span>/mese</span></div>
        <ul class="rv-plan-features">
          <li>Tutto di Essenziale +</li>
          <li>Anagrafica giocatori</li>
          <li>Prestiti e rientri</li>
          <li>Ticket assistenza macchine</li>
          <li>Documenti e firma digitale</li>
          <li>Notifiche push</li>
          <li>Utenti illimitati</li>
        </ul>
      </div>
      <div class="rv-plan">
        <div class="rv-plan-head rv-plan-suite">Suite</div>
        <div class="rv-plan-price">€99<span>/mese</span></div>
        <ul class="rv-plan-features">
          <li>Tutto di Pro +</li>
          <li>White-label completo</li>
          <li>SONOS / Web Radio</li>
          <li>Passaggio consegne</li>
          <li>Confronto periodi</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- ── TECH NOTES ────────────────────────────────────────────── -->
<section class="section rv-tech-section">
  <div class="container">
    <div class="rv-tech-inner reveal">
      <div>
        <div class="rv-section-label">Note tecniche</div>
        <h2>Requisiti di installazione</h2>
        <p class="rv-tech-sub">GestHall Suite è progettato per funzionare su hosting PHP condiviso standard. Nessun container, nessun cloud proprietario, nessuna dipendenza esterna.</p>
      </div>
      <div class="rv-tech-grid">
        <div class="rv-tech-item">
          <div class="rv-tech-label">Server</div>
          <div class="rv-tech-val">PHP 8.1+ · Apache o Nginx</div>
        </div>
        <div class="rv-tech-item">
          <div class="rv-tech-label">Database</div>
          <div class="rv-tech-val">MySQL 8+ o MariaDB 10.6+</div>
        </div>
        <div class="rv-tech-item">
          <div class="rv-tech-label">HTTPS</div>
          <div class="rv-tech-val">Richiesto per PWA e notifiche push</div>
        </div>
        <div class="rv-tech-item">
          <div class="rv-tech-label">Estensioni PHP</div>
          <div class="rv-tech-val">PDO, openssl, mbstring, zip</div>
        </div>
        <div class="rv-tech-item">
          <div class="rv-tech-label">Setup</div>
          <div class="rv-tech-val">Wizard guidato a prima installazione</div>
        </div>
        <div class="rv-tech-item">
          <div class="rv-tech-label">Aggiornamenti</div>
          <div class="rv-tech-val">Manuale via FTP o SSH (no auto-update)</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── CTA ───────────────────────────────────────────────────── -->
<section class="rv-cta">
  <div class="container rv-cta-inner reveal">
    <h2>Pronto a iniziare?</h2>
    <p>Scrivici specificando il numero di sale che gestisci e la tua zona operativa. Risposta entro 48 ore lavorative.</p>
    <a href="/contatti?tipo=rivenditore" class="btn btn-primary btn-lg">Contattaci per il programma rivenditori →</a>
    <p class="rv-cta-note">Oppure scrivi a <a href="mailto:rivenditori@gesthallsuite.it">rivenditori@gesthallsuite.it</a></p>
  </div>
</section>

</Layout>

<style>
/* ── LAYOUT HELPERS ───────────────────────────────────────── */
.container { max-width: 1140px; margin: 0 auto; padding: 0 24px }
.section { padding: 100px 0 }
.btn { display: inline-flex; align-items: center; gap: 6px; padding: 11px 22px; border-radius: var(--rx); font-size: 15px; font-weight: 600; transition: all .18s; text-decoration: none; white-space: nowrap }
.btn-primary { background: var(--accent); color: oklch(100% 0 0) }
.btn-primary:hover { background: var(--accent-dim); transform: translateY(-1px); box-shadow: 0 6px 20px var(--accent-glow) }
.btn-ghost { background: transparent; color: var(--text); border: 1.5px solid var(--border) }
.btn-ghost:hover { background: var(--surface); border-color: var(--border) }
.btn-lg { padding: 14px 30px; font-size: 16px }

/* ── REVEAL ───────────────────────────────────────────────── */
.reveal, .reveal-once { opacity: 0; transform: translateY(20px); transition: opacity .6s var(--ease), transform .6s var(--ease) }
.reveal.visible, .reveal-once.visible { opacity: 1; transform: none }

/* ── SHARED SECTION LABELS ────────────────────────────────── */
.rv-section-label { font-size: 11px; font-weight: 800; letter-spacing: .1em; text-transform: uppercase; color: var(--accent); margin-bottom: 10px }
.rv-section-title { font-family: var(--font-head); font-size: clamp(1.8rem, 2.6vw, 2.5rem); font-weight: 800; color: var(--text); margin-bottom: 16px; line-height: 1.15 }
.rv-section-sub { font-size: 16px; color: var(--muted); max-width: 58ch; line-height: 1.75; margin-bottom: 56px }

/* ── HERO ─────────────────────────────────────────────────── */
.rv-hero { padding: 130px 0 80px; background: linear-gradient(155deg, oklch(100% 0 0), oklch(96.5% 0.01 240)) }
.rv-hero-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 72px; align-items: center }
.rv-breadcrumb { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--muted); margin-bottom: 20px }
.rv-breadcrumb a { color: var(--muted); text-decoration: none }
.rv-breadcrumb a:hover { color: var(--text) }
.rv-breadcrumb span[aria-hidden] { color: var(--faint) }
.rv-tag { display: inline-flex; padding: 5px 13px; border-radius: 999px; background: var(--accent-sub); border: 1px solid oklch(0.72 0.16 168 / 0.25); color: var(--accent); font-size: 12px; font-weight: 700; margin-bottom: 20px }
.rv-hero-text h1 { font-family: var(--font-head); font-size: clamp(2.4rem, 4vw, 3.8rem); font-weight: 800; color: var(--text); line-height: 1.1; margin-bottom: 20px }
.rv-sub { font-size: 16px; color: var(--muted); line-height: 1.75; max-width: 48ch; margin-bottom: 32px }
.rv-actions { display: flex; gap: 12px; flex-wrap: wrap }

/* ── HUB MOCKUP ───────────────────────────────────────────── */
.hub-mock { background: oklch(18% 0.07 245); border: 1px solid oklch(26% 0.085 245); border-radius: 16px; overflow: hidden; font-size: 12px; box-shadow: 0 20px 60px oklch(10% 0.04 245 / 0.35), 0 4px 16px oklch(10% 0.04 245 / 0.2) }
.hub-topbar { display: flex; align-items: center; justify-content: space-between; padding: 10px 14px; background: oklch(14% 0.06 245); border-bottom: 1px solid oklch(22% 0.08 245) }
.hub-topbar-logo { display: flex; align-items: center; gap: 7px; font-size: 12px; font-weight: 700; color: oklch(90% 0.01 245) }
.hub-topbar-user { font-size: 11px; color: oklch(55% 0.04 245) }
.hub-topbar-user::before { content: ''; display: inline-block; width: 6px; height: 6px; background: oklch(0.72 0.16 168); border-radius: 50%; margin-right: 5px }
.hub-body { display: grid; grid-template-columns: 110px 1fr }
