---
import Layout from '../layouts/Layout.astro';
---

<Layout page="404 — Pagina non trovata" description="La pagina che cerchi non esiste o è stata spostata.">

<section class="notfound">
  <div class="container notfound-inner">
    <div class="notfound-num" aria-hidden="true">404</div>
    <h1>Pagina non trovata.</h1>
    <p>La pagina che cerchi non esiste o è stata spostata. Torna alla home o usa la navigazione in alto.</p>
    <div class="notfound-actions">
      <a href="/" class="btn btn-primary">Torna alla home</a>
      <a href="/contatti" class="btn btn-ghost">Contattaci</a>
    </div>
  </div>
</section>

</Layout>

<style>
.notfound {
  min-height: calc(100dvh - 72px);
  display: flex; align-items: center;
  padding: 80px 0;
}
.notfound-inner {
  display: flex; flex-direction: column; align-items: flex-start; gap: 20px;
  max-width: 560px;
}
.notfound-num {
  font-family: var(--font-head); font-size: clamp(5rem, 14vw, 10rem);
  font-weight: 800; color: var(--accent); letter-spacing: -0.06em;
  line-height: 1; opacity: 0.18;
  user-select: none;
}
.notfound-inner h1 {
  font-size: clamp(1.8rem, 3.5vw, 2.8rem); font-weight: 800; margin-top: -16px;
}
.notfound-inner p {
  font-size: 17px; color: var(--muted); line-height: 1.7; max-width: 44ch;
}
.notfound-actions { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 8px }
</style>
