---
import Layout from '../../layouts/Layout.astro';
import { features, byPlan, planLabel } from '../../data/features.ts';
---

<Layout
  page="Funzionalità"
  description="Tutte le funzionalità di GestHall Suite: cassa giornaliera, scassettamenti VLT AWP, turni, firma digitale, app mobile, chat interna e white-label."
>

<section class="fi-hero">
  <div class="container">
    <nav class="fi-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span>Funzionalità</span>
    </nav>
    <h1 class="reveal">Tutto quello che serve<br>per gestire una sala.</h1>
    <p class="fi-sub reveal d1">
      Dal cassetto quotidiano al confronto mensile, dalla firma digitale alla chat interna.
      Tre piani, dieci funzionalità, zero fogli Excel.
    </p>
  </div>
</section>

{(['essenziale', 'pro', 'suite'] as const).map(plan => (
  <section class={`fi-plan-section fi-plan-${plan}`}>
    <div class="container">
      <div class="fi-plan-header reveal">
        <div class={`fi-plan-badge fi-badge-${plan}`}>{planLabel[plan]}</div>
        <div class="fi-plan-price">
          {plan === 'essenziale' && <><span class="fi-from">da</span> €39<span class="fi-mo">/mese</span></>}
          {plan === 'pro'        && <><span class="fi-from">da</span> €69<span class="fi-mo">/mese</span></>}
          {plan === 'suite'      && <><span class="fi-from">da</span> €99<span class="fi-mo">/mese</span></>}
        </div>
        {plan !== 'essenziale' && (
          <div class="fi-plan-includes">
            Include tutto di {plan === 'pro' ? 'Essenziale' : 'Pro'}
          </div>
        )}
      </div>
      <div class="fi-grid">
        {byPlan[plan].map((f, i) => (
          <a href={f.slug} class={`fi-card reveal d${(i % 4) + 1}`}>
            <div class="fi-card-icon" set:html={f.icon}></div>
            <div class="fi-card-body">
              <div class="fi-card-name">{f.name}</div>
              <div class="fi-card-desc">{f.desc}</div>
            </div>
            <svg class="fi-card-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
          </a>
        ))}
      </div>
    </div>
  </section>
))}

<section class="fi-cta-section">
  <div class="container">
    <div class="fi-cta reveal">
      <h2>Prova tutte le funzionalità gratis per 14 giorni.</h2>
      <p>Nessuna carta di credito. Installazione su hosting inclusa nel primo mese.</p>
      <div class="fi-cta-actions">
        <a href="/#demo" class="btn btn-primary">Inizia la prova gratuita</a>
        <a href="/#prezzi" class="btn btn-ghost">Confronta i piani</a>
      </div>
    </div>
  </div>
</section>

</Layout>

<style>
/* Hero */
.fi-hero { padding: 120px 0 72px; background: linear-gradient(155deg, oklch(100% 0 0) 0%, oklch(96% 0.012 245) 100%); border-bottom: 1px solid var(--border-sub) }
.fi-breadcrumb { display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--faint); margin-bottom: 24px }
.fi-breadcrumb a { color: var(--muted); transition: color .15s }
.fi-breadcrumb a:hover { color: var(--text) }
.fi-hero h1 { font-size: clamp(2.4rem, 4vw, 4rem); font-weight: 800; margin-bottom: 20px }
.fi-sub { font-size: 18px; color: var(--muted); max-width: 52ch; line-height: 1.7 }

/* Plan sections */
.fi-plan-section { padding: 72px 0 }
.fi-plan-essenziale { background: var(--bg) }
.fi-plan-pro        { background: var(--surface) }
.fi-plan-suite      { background: var(--bg) }

.fi-plan-header { display: flex; align-items: center; gap: 20px; margin-bottom: 36px; flex-wrap: wrap }
.fi-plan-badge { font-size: 13px; font-weight: 700; padding: 5px 16px; border-radius: 999px }
.fi-badge-essenziale { background: oklch(96% 0.04 168); color: oklch(0.50 0.14 168) }
.fi-badge-pro        { background: oklch(96% 0.04 250); color: oklch(0.45 0.18 250) }
.fi-badge-suite      { background: oklch(96% 0.04 300); color: oklch(0.45 0.18 300) }
.fi-plan-price { font-family: var(--font-head); font-size: 28px; font-weight: 800; color: var(--text); letter-spacing: -0.03em; display: flex; align-items: baseline; gap: 3px }
.fi-from { font-size: 14px; font-weight: 400; color: var(--muted); font-family: var(--font-body) }
.fi-mo   { font-size: 14px; font-weight: 500; color: var(--muted); font-family: var(--font-body) }
.fi-plan-includes { font-size: 13px; color: var(--faint); margin-left: auto }

/* Feature grid */
.fi-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 14px }
.fi-card {
  display: flex; align-items: flex-start; gap: 14px;
  background: var(--bg); border: 1px solid var(--border-sub);
  border-radius: var(--rx-l); padding: 20px 18px;
  transition: all .2s var(--ease); position: relative;
}
.fi-plan-pro .fi-card, .fi-plan-suite .fi-card { background: var(--bg) }
.fi-card:hover { border-color: oklch(0.72 0.16 168 / 0.5); box-shadow: 0 6px 24px var(--accent-glow); transform: translateY(-1px) }
.fi-card-icon {
  width: 40px; height: 40px; flex-shrink: 0;
  background: var(--accent-sub); border-radius: var(--rx);
  display: flex; align-items: center; justify-content: center;
  color: var(--accent); padding: 10px;
}
.fi-card-icon svg { width: 100%; height: 100% }
.fi-card-body { flex: 1; min-width: 0 }
.fi-card-name { font-size: 15px; font-weight: 700; color: var(--text); margin-bottom: 4px }
.fi-card-desc { font-size: 13px; color: var(--muted); line-height: 1.5 }
.fi-card-arrow { color: var(--faint); flex-shrink: 0; margin-top: 2px; transition: transform .2s var(--ease), color .2s }
.fi-card:hover .fi-card-arrow { transform: translateX(3px); color: var(--accent) }

/* CTA */
.fi-cta-section { padding: 80px 0; background: var(--navy) }
.fi-cta { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 20px; max-width: 580px; margin: 0 auto }
.fi-cta h2 { font-size: clamp(1.8rem, 3vw, 2.6rem); color: oklch(93% 0.008 245) }
.fi-cta p { font-size: 16px; color: oklch(55% 0.04 245) }
.fi-cta-actions { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center }

@media (max-width: 640px) {
  .fi-hero { padding: 96px 0 56px }
  .fi-plan-includes { margin-left: 0 }
  .fi-grid { grid-template-columns: 1fr }
}
</style>
