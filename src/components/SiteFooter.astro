---
---
<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="slogo" aria-label="GestHall Suite">
        <svg width="28" height="28" viewBox="0 0 34 34" aria-hidden="true">
          <rect width="34" height="34" rx="8" fill="oklch(0.72 0.16 168)"/>
          <rect x="6"  y="6"  width="9" height="10" rx="2" fill="oklch(0.1 0 0 / 0.32)"/>
          <rect x="19" y="6"  width="9" height="10" rx="2" fill="oklch(0.1 0 0 / 0.32)"/>
          <rect x="6"  y="19" width="9" height="10" rx="2" fill="oklch(0.1 0 0 / 0.32)"/>
          <rect x="19" y="19" width="9" height="10" rx="2" fill="oklch(0.1 0 0 / 0.72)"/>
        </svg>
        <span class="slogo-name">GestHall <strong>Suite</strong></span>
      </a>
      <p class="footer-tagline">Il gestionale per le sale giochi italiane.</p>
    </div>
    <nav class="footer-links" aria-label="Link footer">
      <div class="footer-col">
        <span class="footer-col-head">Prodotto</span>
        <a href="/#funzionalita">Funzionalità</a>
        <a href="/#prezzi">Prezzi</a>
        <a href="/#demo">Demo gratuita</a>
        <a href="/docs">Documentazione</a>
      </div>
      <div class="footer-col">
        <span class="footer-col-head">Azienda</span>
        <a href="/#rivenditori">Rivenditori</a>
        <a href="/contatti">Contatti</a>
      </div>
      <div class="footer-col">
        <span class="footer-col-head">Legale</span>
        <a href="/privacy">Privacy Policy</a>
        <a href="/termini">Termini di servizio</a>
      </div>
    </nav>
  </div>
  <div class="container footer-bottom">
    <span>© 2026 GestHall Suite. Tutti i diritti riservati.</span>
    <div class="footer-bottom-links">
      <a href="/privacy">Privacy</a>
      <a href="/contatti">Contatti</a>
    </div>
  </div>
</footer>

<style>
.site-footer {
  background: oklch(19% 0.075 245);
  border-top: 1px solid oklch(26% 0.085 245);
  padding: 64px 0 0;
}
.footer-inner { display: grid; grid-template-columns: 1fr auto; gap: 64px; padding-bottom: 48px }
.slogo { display: flex; align-items: center; gap: 10px; margin-bottom: 12px }
.slogo-name {
  font-family: var(--font-head); font-size: 18px; font-weight: 300;
  letter-spacing: -0.03em; color: oklch(93% 0.008 245);
}
.slogo-name strong { font-weight: 700 }
.footer-tagline { font-size: 14px; color: oklch(50% 0.04 245) }
.footer-links { display: flex; gap: 48px }
.footer-col { display: flex; flex-direction: column; gap: 10px }
.footer-col-head {
  font-size: 12px; font-weight: 700; color: oklch(78% 0.02 245);
  text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 4px;
}
.footer-col a { font-size: 14px; color: oklch(50% 0.04 245); transition: color 0.15s }
.footer-col a:hover { color: oklch(82% 0.02 245) }
.footer-bottom {
  padding: 20px 0; border-top: 1px solid oklch(26% 0.085 245);
  font-size: 13px; color: oklch(40% 0.04 245);
  display: flex; justify-content: space-between; align-items: center;
}
.footer-bottom-links { display: flex; gap: 16px }
.footer-bottom-links a { color: oklch(40% 0.04 245); transition: color 0.15s }
.footer-bottom-links a:hover { color: oklch(65% 0.035 245) }

@media (max-width: 900px) {
  .footer-inner { grid-template-columns: 1fr; gap: 40px }
  .footer-links { flex-wrap: wrap; gap: 32px }
}
@media (max-width: 640px) {
  .footer-bottom { flex-direction: column; gap: 8px; text-align: center }
}
</style>
